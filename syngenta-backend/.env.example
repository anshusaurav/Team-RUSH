MONGODB_URI=mongodb://localhost:27017/syngenta
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
AI_PROVIDER=gemini
PORT=3001
DATASET_PATH=../dataset

# Optional: bootstrap synthetic data forward to yesterday on startup.
# See src/services/dataExtender.ts for the generation rules.
EXTEND_DATA_TO_YESTERDAY=false
EXTEND_MAX_DAYS=60
EXTEND_SEASONALITY=false
